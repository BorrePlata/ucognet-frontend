import React from 'react';
import { Container, Box, Typography, Grid } from '@mui/material';
import SectionTitle from '../components/SectionTitle';
import InfoCard from '../components/InfoCard';
import CTAButton from '../components/CTAButton';
import ContactForm from '../components/ContactForm';
import NewsletterSection from '../components/NewsletterSection';

export default function NuevaSeccion() {
  return (
    <Container>
      {/* Encabezado */}
      <SectionTitle title="Título de la Nueva Sección" subtitle="Un subtítulo relevante para esta sección" />

      {/* Descripción */}
      <Box mb={4}>
        <Typography variant="body1">
          Descripción breve sobre el contenido de esta sección. Proporciona una introducción clara y atractiva.
        </Typography>
      </Box>

      {/* Cuadros de Contenido */}
      <Grid container spacing={3}>
        <Grid item xs={12} sm={6} md={4}>
          <InfoCard icon={<Icon1 />} title="Título 1" description="Descripción breve." />
        </Grid>
        <Grid item xs={12} sm={6} md={4}>
          <InfoCard icon={<Icon2 />} title="Título 2" description="Descripción breve." />
        </Grid>
        <Grid item xs={12} sm={6} md={4}>
          <InfoCard icon={<Icon3 />} title="Título 3" description="Descripción breve." />
        </Grid>
      </Grid>

      {/* Llamado a la Acción */}
      <Box textAlign="center" mt={4}>
        <CTAButton label="Contáctanos" color="primary" />
      </Box>

      {/* Formulario de Contacto y Newsletter */}
      <ContactForm />
      <NewsletterSection />
    </Container>
  );
}
Conclusión
Esta metodología te permitirá mantener un diseño consistente, profesional y fácil de escalar para cualquier página interna. La estructura modular y el uso de un theme.js centralizado aseguran que el proyecto sea altamente flexible y preparado para futuras expansiones.






